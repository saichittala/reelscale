{
  "name": "reelscale-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "build:static": "mv app/api _api_bak && NEXT_PUBLIC_STATIC_EXPORT=true next build; mv _api_bak app/api",
    "deploy": "npm run build:static && gh-pages -d out"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "gh-pages": "^6.3.0",
    "typescript": "5.8.3"
  }
}
